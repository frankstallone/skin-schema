---
const examples = [
  {
    src: '/media/videos/short-01.mp4',
    label: 'Short-form skincare product texture video',
  },
  {
    src: '/media/videos/short-02.mp4',
    label: 'Short-form beauty routine product video',
  },
  {
    src: '/media/videos/short-03.mp4',
    label: 'Short-form makeup and skincare product video',
  },
];
---

<div
  class="wrapper region flow relative overflow-x-auto"
  id="ShortFormExamples"
  style="padding-right: 0 !important"
>
  <div class="box w-fit mx-auto text-center">
    <h2>Short form product examples</h2>
  </div>

  <div class="reel short-form-reel" aria-label="Short form product examples">
    {
      examples.map((example) => (
        <figure class="short-form-example">
          <video
            class="short-form-example__video"
            controls
            loop
            muted
            playsinline
            preload="none"
            aria-label={example.label}
            data-src={example.src}
          />
          <figcaption class="visually-hidden">{example.label}</figcaption>
        </figure>
      ))
    }
  </div>

  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 512 512"
    fill="currentColor"
    class="icon absolute right-m-l bottom-l-xl animate-bounce-right text-gray-900"
  >
    <title>Scroll to the right to see more</title>
    <path
      d="M334.5 414c8.8 3.8 19 2 26-4.6l144-136c4.8-4.5 7.5-10.8 7.5-17.4s-2.7-12.9-7.5-17.4l-144-136c-7-6.6-17.2-8.4-26-4.6s-14.5 12.5-14.5 22l0 72L32 192c-17.7 0-32 14.3-32 32l0 64c0 17.7 14.3 32 32 32l288 0 0 72c0 9.6 5.7 18.2 14.5 22z"
    ></path></svg
  >
</div>

<script>
  const loadVideo = (video: HTMLVideoElement) => {
    if (!video.dataset.src || video.querySelector('source')) {
      return;
    }

    const source = document.createElement('source');
    source.src = video.dataset.src;
    source.type = 'video/mp4';
    video.append(source);
    video.load();
  };

  const videos = document.querySelectorAll<HTMLVideoElement>(
    '.short-form-example__video[data-src]',
  );

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }

          loadVideo(entry.target as HTMLVideoElement);
          observer.unobserve(entry.target);
        });
      },
      {
        rootMargin: '300px 100%',
      },
    );

    videos.forEach((video) => observer.observe(video));
  } else {
    videos.forEach(loadVideo);
  }
</script>

<style>
  .short-form-reel {
    align-items: stretch;
    padding-block-end: var(--spacing-s);
  }

  .short-form-example {
    aspect-ratio: 9 / 16;
    background: var(--color-gray-1200);
    border: 1px solid var(--color-gray-1000);
    border-radius: 8px;
    inline-size: clamp(16rem, 72vw, 22rem);
    margin: 0;
    overflow: hidden;
  }

  .short-form-example__video {
    block-size: 100%;
    display: block;
    inline-size: 100%;
    object-fit: cover;
  }

</style>
