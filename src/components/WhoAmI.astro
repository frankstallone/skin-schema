---
import { Picture } from 'astro:assets';
import selfie from '../assets/photograph-of-skin-schema.jpg';

const { class: className } = Astro.props;
---

<section
  class={`wrapper region flow prose ${className ? className : ''}`}
  id="main"
>
  <ul class="grid" data-layout="50-50" role="list">
    <li class="flex flex-col justify-start items-center flow prose">
      <h2 class="-rotate-2 mb-xl">
        <mark><span>Meet Kseniya 👋🏻</span></mark>
      </h2>
      <p class="text-step-2 leading-snug">
        I'm an experienced beauty photographer and videographer with work across
        20+ brands and approximately 40 campaigns. I created Skin Schema to
        bring polish, serenity, and credible product storytelling to skincare,
        makeup, and wellness content.
      </p>
      <p class="text-step-0 leading-snug">
        I partner with select brands that want content to feel elevated without
        losing the honesty, texture, and lived-in detail that makes beauty
        audiences trust a recommendation.
      </p>
      <p class="text-step-0 leading-snug">
        Skin Schema creates short-form video, premium product storytelling,
        texture visuals, and photo sets designed for social, campaign, and brand
        content.
      </p>
      <details-utils close-click-outside class="self-start">
        <details>
          <summary class="my-xs font-mono font-semibold"
            >Learn more about me...</summary
          >
          <section>
            <p class="text-step-0">
              I combine beauty specialization, professional equipment, and a
              minimal visual style to create assets that are ready for launch
              campaigns, social calendars, product education, and brand
              storytelling. Whether you need content for your own channels or a
              selective Skin Schema feature, I offer the bespoke collaboration
              options below.
            </p>
            <p class="text-step-0">
              If you'd like to discuss any of these options in more detail, <a
                href="/#Contact"
              >
                send me a note below
              </a> or just <a
                href="https://www.instagram.com/skinschema/"
                target="_blank"
                aria-label="Opens in new tab">pop me a DM on Instagram</a
              >.
            </p>
          </section>
        </details>
      </details-utils>
    </li>
    <li class="flex justify-center items-center">
      <Picture
        src={selfie}
        widths={[300, 800, selfie.width]}
        sizes={`(max-width: 300px) 300px, (max-width: 800px) 800px,  ${selfie.width}px`}
        alt="Photograph of the creator of Skin Schema"
        class="h-auto max-w-screen-sm object-cover"
        quality={80}
        format="avif"
        decoding="sync"
        loading="eager"
      />
    </li>
  </ul>
  <div class="box w-fit mx-auto text-center">
    <h2>Brands partner with me because:</h2>
  </div>
  <ul class="grid" role="list" data-layout="thirds">
    <li
      class="border border-gray-600 flex flex-col justify-between drop rounded-2xl overflow-clip text-center"
    >
      <div class="box flow prose">
        <h3 class="mt-zero text-step-1">Authenticity at scale</h3>
        <p>
          Creator-led visuals that feel credible, specific, and true to how
          beauty customers actually discover products.
        </p>
      </div>
    </li>
    <li
      class="border border-gray-600 flex flex-col justify-between drop rounded-2xl overflow-clip text-center"
    >
      <div class="box flow prose">
        <h3 class="mt-zero text-step-1">Brand-ready polish</h3>
        <p>
          Concepting, shooting, and editing are handled with a refined visual
          standard your team can use across launches, socials, and campaigns.
        </p>
      </div>
    </li>
    <li
      class="border border-gray-600 flex flex-col justify-between drop rounded-2xl overflow-clip text-center"
    >
      <div class="box flow prose">
        <h3 class="mt-zero text-step-1">Beauty niche fit</h3>
        <p>
          A focused understanding of skincare, makeup, wellness, product
          textures, routines, and the details that make beauty content convert.
        </p>
      </div>
    </li>
  </ul>
</section>
<script src="@zachleat/details-utils/details-utils.js"></script>
