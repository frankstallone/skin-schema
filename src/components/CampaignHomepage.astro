---
import { Picture } from 'astro:assets';
import creatorPortrait from '../assets/photograph-of-skin-schema.jpg';
import campaignStill from '../assets/2023-Creative-Minds-29-web.jpg';
import photoExample03 from '../assets/photo-example-03.jpg';
import photoExample04 from '../assets/photo-example-04.jpg';
import partnership01 from '../assets/paid-partnership/2023-Creative-Minds-14.jpg';
import valentino from '../assets/workedwith/valentino@2x.png';
import armani from '../assets/workedwith/armani-beauty.png';
import naturopathica from '../assets/workedwith/naturopathica.png';
import queen from '../assets/workedwith/queen-musia.avif';
import saya from '../assets/workedwith/saya.webp';

type BrandLogo = {
  src: ImageMetadata;
  alt: string;
  className: string;
};

const pathname = Astro.url.pathname;

const brandLogos: BrandLogo[] = [
  {
    src: valentino,
    alt: 'Skin Schema has worked with Valentino',
    className: 'max-h-[20px]',
  },
  {
    src: armani,
    alt: 'Skin Schema has worked with Armani Beauty',
    className: 'max-h-[40px]',
  },
  {
    src: naturopathica,
    alt: 'Skin Schema has worked with Naturopathica',
    className: 'max-h-[20px]',
  },
  {
    src: queen,
    alt: 'Skin Schema has worked with Queen Musia',
    className: 'max-h-[20px]',
  },
  {
    src: saya,
    alt: 'Skin Schema has worked with Saya',
    className: 'max-h-[20px]',
  },
];

const proofPoints = [
  {
    title: 'Authenticity at scale',
    text: 'Creator-led visuals that feel credible, specific, and true to how beauty customers actually discover products.',
  },
  {
    title: 'Brand-ready polish',
    text: 'Concepting, shooting, and editing are handled with a refined visual standard your team can use across launches, socials, and campaigns.',
  },
  {
    title: 'Beauty niche fit',
    text: 'A focused understanding of skincare, makeup, wellness, product textures, routines, and the details that make beauty content convert.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Concepting',
    text: 'Product showcases, unboxings, how-tos, before-and-afters, hooks, and beauty routines.',
  },
  {
    number: '02',
    title: 'Shooting',
    text: 'Polished production, product context, lifestyle detail, and Skin Schema-style serenity.',
  },
  {
    number: '03',
    title: 'Delivery',
    text: 'Content for social channels, launch moments, campaigns, and product education.',
  },
];

const startingRates = [
  {
    title: 'Product Photo Sets',
    type: 'Photo Set',
    price: '$250',
    text: 'Refined product photography and texture visuals for skincare, makeup, and wellness brands.',
    specs: [
      ['Assets', '3'],
      ['Turnaround', '2 weeks'],
      ['Revisions', '1'],
      ['Length', 'N/A'],
    ],
  },
  {
    title: 'Short-Form Product Videos',
    type: 'Short Video',
    price: '$500',
    text: 'Elevated short-form videos for product showcases, unboxings, how-tos, before-and-afters, hooks, and beauty routines.',
    specs: [
      ['Assets', '1'],
      ['Turnaround', '2 weeks'],
      ['Revisions', '1'],
      ['Length', 'Up to 12 seconds'],
    ],
  },
  {
    title: 'Product Storytelling Videos',
    type: 'Storytelling Video',
    price: '$750',
    text: 'More developed beauty video concepts with polished production, product context, lifestyle detail, and campaign-style pacing.',
    specs: [
      ['Assets', '1'],
      ['Turnaround', '2 weeks'],
      ['Revisions', '1'],
      ['Length', 'Up to 20 seconds'],
    ],
  },
];
---

<div class="campaign-homepage" id="main">
  <header class="campaign-nav" aria-label="Primary">
    <a href="#main" class="campaign-brand">Skin Schema</a>
    <nav>
      <a href="#CampaignProcess">Process</a>
      <a href="#CampaignRates">Rates</a>
      <a href="#Contact">Contact</a>
    </nav>
  </header>

  <section class="campaign-hero" aria-labelledby="campaign-hero-title">
    <div class="campaign-hero__copy">
      <p class="campaign-kicker">Campaign-ready content</p>
      <h1 id="campaign-hero-title">
        Brand-ready output suitable for campaigns, social content, and product
        storytelling
      </h1>
      <p>
        Skin Schema creates elevated skincare, makeup, and wellness content with
        the polish of a campaign asset and the trust of a real creator
        recommendation.
      </p>
      <a href="#Contact" class="campaign-button campaign-button--light"
        >Let's connect</a
      >
    </div>
    <div
      class="campaign-storyboard"
      aria-label="Product storytelling video examples"
    >
      <video autoplay loop muted playsinline preload="metadata">
        <source src="/media/videos/premium-01.mp4" type="video/mp4" />
      </video>
      <video autoplay loop muted playsinline preload="metadata">
        <source src="/media/videos/premium-02.mp4" type="video/mp4" />
      </video>
      <video autoplay loop muted playsinline preload="metadata">
        <source src="/media/videos/premium-03.mp4" type="video/mp4" />
      </video>
    </div>
  </section>

  <section class="campaign-brands" aria-label="Brands we've worked with">
    <p class="campaign-kicker">Brands we've worked with</p>
    <ul role="list">
      {
        brandLogos.map((logo) => (
          <li>
            <Picture
              src={logo.src}
              alt={logo.alt}
              class={`object-contain w-auto h-auto ${logo.className}`}
              formats={['avif', 'webp']}
            />
          </li>
        ))
      }
    </ul>
  </section>

  <section class="campaign-creator" aria-labelledby="campaign-creator-title">
    <div class="campaign-creator__portrait">
      <Picture
        src={creatorPortrait}
        alt="Photograph of Kseniya, the creator behind Skin Schema"
        class="campaign-creator__primary-image"
        widths={[320, 640, creatorPortrait.width]}
        sizes="(max-width: 900px) 68vw, 34vw"
        quality={80}
        format="avif"
      />
      <Picture
        src={campaignStill}
        alt="Beauty campaign still by Skin Schema"
        class="campaign-creator__supporting-image"
        widths={[180, 360, 640]}
        sizes="(max-width: 900px) 28vw, 1px"
        quality={80}
        format="avif"
      />
    </div>
    <div class="campaign-creator__copy">
      <p class="campaign-kicker">Meet Kseniya</p>
      <h2 id="campaign-creator-title">
        Creator-led beauty production with campaign-level polish.
      </h2>
      <p>
        I'm an experienced beauty photographer and videographer with work across
        20+ brands and approximately 40 campaigns. I created Skin Schema to
        bring polish, serenity, and credible product storytelling to skincare,
        makeup, and wellness content.
      </p>
      <ul role="list">
        {
          proofPoints.map((point) => (
            <li>
              <strong>{point.title}</strong>
              <p>{point.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="campaign-range" aria-label="Content range">
    <Picture
      src={photoExample03}
      alt="Skincare product photography by Skin Schema"
      format="avif"
      quality={80}
    />
    <video autoplay loop muted playsinline preload="metadata">
      <source src="/media/videos/short-02.mp4" type="video/mp4" />
    </video>
    <Picture
      src={photoExample04}
      alt="Editorial lipstick product photography by Skin Schema"
      format="avif"
      quality={80}
    />
    <Picture
      src={partnership01}
      alt="Beauty product partnership image by Skin Schema"
      format="avif"
      quality={80}
    />
  </section>

  <section class="campaign-system" id="CampaignProcess">
    <h2>Execution, scoped for brand teams</h2>
    <ol>
      {
        processSteps.map((step) => (
          <li>
            <span>{step.number}</span>
            <strong>{step.title}</strong>
            <p>{step.text}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="campaign-rates" id="CampaignRates">
    <div class="campaign-rates__intro">
      <p class="campaign-kicker">Starting rates</p>
      <h2>Simple entry points, scoped with campaign detail.</h2>
      <p>
        Custom bundles, usage, raw footage, and campaign-specific needs are
        quoted after we align on scope.
      </p>
    </div>
    <div class="campaign-rate-bands">
      {
        startingRates.map((rate) => (
          <article>
            <div>
              <p>{rate.type}</p>
              <span>{rate.price}</span>
            </div>
            <div>
              <h3>{rate.title}</h3>
              <p>{rate.text}</p>
            </div>
            <dl>
              {rate.specs.map(([label, value]) => (
                <div>
                  <dt>{label}</dt>
                  <dd>{value}</dd>
                </div>
              ))}
            </dl>
          </article>
        ))
      }
    </div>
    <div class="campaign-rates__note">
      <p>
        Organic brand-use rights are included for approved channels. Paid usage,
        raw footage, rush delivery, perpetual usage, and extended distribution
        are quoted separately based on campaign scope.
      </p>
    </div>
  </section>

  <section class="campaign-contact" id="Contact">
    <div>
      <p class="campaign-kicker">Let's connect</p>
      <h2>
        If our approach to beauty and aesthetics align, I'd love to talk more.
      </h2>
      <p>
        Send a few details about the product, launch, timeline, and where the
        content needs to live. I'll be in touch within 24 hours so we can shape
        the right scope.
      </p>
    </div>
    <form
      name="campaign-contact"
      netlify-honeypot="bot-field"
      method="POST"
      data-netlify="true"
      action="/thank-you/"
      class="campaign-contact__form"
    >
      <div class="hidden">
        <input type="hidden" name="form-name" value="campaign-contact" />
        <input
          type="hidden"
          name="subject"
          value={`Form submission: skinschema.com${pathname}`}
        />
        <span>
          <label for="campaign-bot-field">Do you like delicious treats?</label>
          <input name="bot-field" id="campaign-bot-field" />
        </span>
      </div>
      <div class="campaign-contact__fields">
        <span>
          <label for="campaign-name">Name</label>
          <input id="campaign-name" name="name" type="text" required />
        </span>
        <span>
          <label for="campaign-email">Email</label>
          <input id="campaign-email" name="email" type="email" required />
        </span>
        <span class="campaign-contact__message">
          <label for="campaign-message"
            >How would you like to work together?</label
          >
          <textarea name="message" id="campaign-message" rows="5" required
          ></textarea>
        </span>
      </div>
      <button type="submit" class="campaign-button campaign-contact__submit">
        Submit
      </button>
    </form>
  </section>

  <footer class="campaign-footer" aria-label="Footer">
    <a href="#main" class="campaign-brand">Skin Schema</a>
    <nav aria-label="Footer navigation">
      <a href="#CampaignProcess">Process</a>
      <a href="#CampaignRates">Rates</a>
      <a href="#Contact">Contact</a>
      <a
        href="https://www.instagram.com/skinschema/"
        target="_blank"
        rel="noopener noreferrer">Instagram</a
      >
    </nav>
  </footer>
</div>

<style>
  :global(html),
  :global(body) {
    background: var(--color-gray-1200);
  }

  .campaign-homepage {
    --campaign-ink: var(--color-gray-1200);
    --campaign-paper: var(--color-gray-100);
    --campaign-warm: var(--color-skin-200);
    --campaign-soft: var(--color-skin-100);
    background: var(--campaign-paper);
    color: var(--campaign-ink);
    min-block-size: 100vh;
  }

  .campaign-nav,
  .campaign-footer {
    align-items: center;
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--text-step-000);
    font-weight: var(--font-weight-black);
    gap: var(--spacing-s);
    justify-content: space-between;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .campaign-nav {
    color: var(--color-gray-100);
    inset-block-start: 0;
    padding: var(--spacing-xs) var(--spacing-s-l);
    position: absolute;
    inline-size: 100%;
    z-index: 4;
  }

  .campaign-nav nav,
  .campaign-footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs-s);
    justify-content: end;
  }

  .campaign-nav a,
  .campaign-footer a {
    color: currentColor;
    text-decoration: none;
  }

  .campaign-nav a:focus-visible,
  .campaign-footer a:focus-visible,
  .campaign-button:focus-visible {
    outline: 2px solid var(--campaign-soft);
    outline-offset: 0.25rem;
  }

  .campaign-brand {
    font-family: var(--font-mono);
    font-weight: var(--font-weight-black);
    text-transform: uppercase;
  }

  .campaign-kicker {
    font-family: var(--font-mono);
    font-size: var(--text-step-000);
    font-weight: var(--font-weight-black);
    margin: 0;
    max-inline-size: none;
    text-transform: uppercase;
  }

  .campaign-button {
    background: var(--campaign-ink);
    border-radius: 999px;
    color: var(--campaign-paper);
    display: inline-flex;
    font-weight: var(--font-weight-bold);
    inline-size: fit-content;
    padding: var(--spacing-2xs) var(--spacing-l);
    text-decoration: none;
    transition:
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .campaign-button:hover {
    transform: translateY(-1px);
  }

  .campaign-button--light {
    background: var(--campaign-paper);
    color: var(--campaign-ink);
  }

  .campaign-hero {
    background: var(--campaign-ink);
    color: var(--campaign-paper);
    display: grid;
    gap: var(--spacing-xl);
    grid-template-columns: minmax(18rem, 0.8fr) minmax(20rem, 1fr);
    min-block-size: 100vh;
    overflow: hidden;
    padding: var(--spacing-3xl) var(--spacing-s-l) var(--spacing-xl);
  }

  .campaign-hero__copy {
    align-self: center;
    display: grid;
    gap: var(--spacing-s);
    max-inline-size: 52rem;
  }

  .campaign-hero__copy h1 {
    font-size: clamp(2.75rem, 6.5vw, 6.5rem);
    line-height: 0.96;
    margin: 0;
    max-inline-size: 11ch;
  }

  .campaign-hero__copy p:not(.campaign-kicker) {
    font-size: var(--text-step-1);
    margin: 0;
    max-inline-size: 42rem;
  }

  .campaign-storyboard {
    align-items: end;
    display: grid;
    gap: var(--spacing-xs);
    grid-template-columns: repeat(3, 1fr);
  }

  .campaign-storyboard video {
    aspect-ratio: 9 / 16;
    block-size: 100%;
    border: 1px solid rgb(255 255 255 / 0.18);
    inline-size: 100%;
    object-fit: cover;
  }

  .campaign-storyboard video:nth-child(2) {
    transform: translateY(calc(-1 * var(--spacing-xl)));
  }

  .campaign-brands {
    align-items: center;
    background: var(--campaign-ink);
    border-block: 1px solid rgb(255 255 255 / 0.16);
    color: var(--campaign-paper);
    display: grid;
    gap: var(--spacing-xl);
    grid-template-columns: minmax(12rem, 0.32fr) minmax(0, 1fr);
    padding: var(--spacing-m-l) var(--spacing-s-l);
  }

  .campaign-brands .campaign-kicker {
    color: var(--color-gray-400);
  }

  .campaign-brands ul {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-l-xl);
    justify-content: end;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .campaign-brands li {
    align-items: center;
    display: flex;
    justify-content: center;
    min-block-size: 2.5rem;
  }

  .campaign-brands picture {
    filter: invert(1) grayscale(1);
    opacity: 0.76;
  }

  .campaign-brands img {
    max-inline-size: 100%;
  }

  .campaign-creator {
    background: color-mix(
      in oklab,
      var(--campaign-ink) 94%,
      var(--campaign-warm)
    );
    color: var(--campaign-paper);
    display: grid;
    gap: var(--spacing-xl);
    grid-template-columns: minmax(16rem, 0.42fr) minmax(22rem, 0.78fr);
    padding: var(--spacing-2xl) var(--spacing-s-l);
  }

  .campaign-creator__portrait picture,
  .campaign-creator__portrait img {
    block-size: 100%;
    inline-size: 100%;
  }

  .campaign-creator__portrait img {
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .campaign-creator__supporting-image {
    display: none;
  }

  .campaign-creator__copy {
    align-self: center;
    display: grid;
    gap: var(--spacing-s);
  }

  .campaign-creator h2,
  .campaign-system h2,
  .campaign-contact h2 {
    font-size: clamp(2.75rem, 6vw, 6rem);
    line-height: 0.96;
    margin: 0;
    max-inline-size: 12ch;
  }

  .campaign-creator__copy > p {
    font-size: var(--text-step-1);
    margin: 0;
    max-inline-size: 56rem;
  }

  .campaign-creator ul {
    display: grid;
    gap: var(--spacing-s);
    grid-template-columns: repeat(3, 1fr);
    list-style: none;
    margin: var(--spacing-m) 0 0;
    padding: 0;
  }

  .campaign-creator li {
    border-block-start: 1px solid rgb(255 255 255 / 0.22);
    padding-block-start: var(--spacing-s);
  }

  .campaign-creator li p {
    color: var(--color-gray-300);
    margin-block-end: 0;
  }

  .campaign-range {
    background: var(--campaign-ink);
    display: grid;
    gap: var(--spacing-xs);
    grid-template-columns: 1fr 0.62fr 1fr 0.82fr;
    padding: var(--spacing-xs) var(--spacing-s-l) var(--spacing-2xl);
  }

  .campaign-range img,
  .campaign-range video {
    aspect-ratio: 4 / 5;
    block-size: 100%;
    inline-size: 100%;
    object-fit: cover;
  }

  .campaign-range video {
    aspect-ratio: 9 / 16;
  }

  .campaign-system {
    background: color-mix(
      in oklab,
      var(--campaign-ink) 94%,
      var(--campaign-warm)
    );
    color: var(--campaign-paper);
    padding: var(--spacing-2xl) var(--spacing-s-l);
  }

  .campaign-system h2 {
    margin-block-end: var(--spacing-xl);
  }

  .campaign-system ol {
    display: grid;
    gap: var(--spacing-m);
    grid-template-columns: repeat(3, 1fr);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .campaign-system li {
    border-block-start: 1px solid rgb(255 255 255 / 0.22);
    display: grid;
    gap: var(--spacing-xs);
    padding-block-start: var(--spacing-s);
  }

  .campaign-system span {
    color: var(--campaign-soft);
    font-family: var(--font-mono);
    font-size: var(--text-step-000);
    font-weight: var(--font-weight-black);
  }

  .campaign-system p {
    color: var(--color-gray-300);
    margin: 0;
  }

  .campaign-rates {
    background: var(--campaign-warm);
    color: var(--campaign-ink);
    padding: var(--spacing-2xl) var(--spacing-s-l);
  }

  .campaign-rates__intro {
    display: grid;
    gap: var(--spacing-s);
    margin-block-end: var(--spacing-xl);
    max-inline-size: 50rem;
  }

  .campaign-rates__intro h2 {
    font-size: clamp(2.75rem, 6vw, 6rem);
    line-height: 0.96;
    margin: 0;
    max-inline-size: 11ch;
  }

  .campaign-rates__intro p {
    margin: 0;
  }

  .campaign-rate-bands {
    display: grid;
    margin-block-start: var(--spacing-xl);
    margin-inline: calc(var(--spacing-s-l) * -1);
  }

  .campaign-rate-bands article {
    background: color-mix(
      in oklab,
      var(--campaign-ink) 96%,
      var(--campaign-warm)
    );
    border-block-start: 1px solid rgb(255 255 255 / 0.18);
    color: var(--campaign-paper);
    display: grid;
    gap: var(--spacing-l);
    grid-template-columns: minmax(12rem, 0.42fr) minmax(18rem, 0.7fr) minmax(
        18rem,
        0.88fr
      );
    padding: var(--spacing-l) var(--spacing-s-l);
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .campaign-rate-bands article:hover {
    background: color-mix(
      in oklab,
      var(--campaign-ink) 92%,
      var(--campaign-warm)
    );
  }

  .campaign-rate-bands article:first-child {
    border-block-start: 0;
  }

  .campaign-rate-bands article > div {
    display: grid;
    gap: var(--spacing-xs);
  }

  .campaign-rate-bands article > div:first-child p {
    color: var(--color-gray-400);
    font-family: var(--font-mono);
    font-size: var(--text-step-000);
    font-weight: var(--font-weight-black);
    margin: 0;
    max-inline-size: none;
    text-transform: uppercase;
  }

  .campaign-rate-bands span {
    color: var(--campaign-soft);
    font-family: var(--font-mono);
    font-size: clamp(3rem, 7vw, 7rem);
    font-weight: var(--font-weight-black);
    line-height: 0.9;
  }

  .campaign-rate-bands h3 {
    font-size: var(--text-step-3);
    line-height: 1;
    margin: 0;
  }

  .campaign-rate-bands article p {
    margin: 0;
  }

  .campaign-rate-bands dl {
    align-self: end;
    display: grid;
    gap: var(--spacing-2xs);
    margin: 0;
  }

  .campaign-rate-bands dl div {
    align-items: baseline;
    border-block-start: 1px solid rgb(255 255 255 / 0.18);
    display: flex;
    gap: var(--spacing-s);
    justify-content: space-between;
    padding-block-start: var(--spacing-2xs);
  }

  .campaign-rate-bands dt {
    color: var(--color-gray-400);
    font-family: var(--font-mono);
    font-size: var(--text-step-000);
    font-weight: var(--font-weight-black);
    text-transform: uppercase;
  }

  .campaign-rate-bands dd {
    font-weight: var(--font-weight-bold);
    margin: 0;
    text-align: end;
  }

  .campaign-rates__note {
    border-block-start: 1px solid var(--color-gray-800);
    margin-block-start: var(--spacing-xl);
    padding-block-start: var(--spacing-s);
  }

  .campaign-rates__note p {
    color: var(--color-gray-1100);
    font-size: var(--text-step-00);
    margin: 0;
    max-inline-size: 75ch;
  }

  .campaign-contact {
    align-items: start;
    background: color-mix(
      in oklab,
      var(--campaign-ink) 97%,
      var(--campaign-warm)
    );
    border-block-start: 1px solid rgb(255 255 255 / 0.18);
    color: var(--campaign-paper);
    display: grid;
    gap: var(--spacing-xl);
    grid-template-columns: minmax(0, 0.72fr) minmax(20rem, 0.78fr);
    padding: var(--spacing-2xl) var(--spacing-s-l);
  }

  .campaign-contact h2 {
