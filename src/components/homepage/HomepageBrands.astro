---
import { Picture } from 'astro:assets';
import { brandLogos } from './data';
import { homepageKicker } from './classes';
---

<section class="homepage-brands" aria-label="Brands we've worked with">
  <p class={`${homepageKicker} text-gray-400 max-[900px]:hidden`}>
    Brands we've worked with
  </p>
  <ul role="list">
    {
      brandLogos.map((logo) => (
        <li>
          <Picture
            src={logo.src}
            alt={logo.alt}
            class={`object-contain w-auto h-auto ${logo.className}`}
            formats={['avif', 'webp']}
          />
        </li>
      ))
    }
  </ul>
</section>
