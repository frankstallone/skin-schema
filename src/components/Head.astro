---
import '../css/global.css';
interface Props {
  title?: string;
  description?: string;
  canonicalURL?: URL | string;
  image?: string;
  imageAlt?: string;
  themeColor?: string;
  statusBarStyle?: 'default' | 'black' | 'black-translucent';
}

const {
  title,
  description,
  canonicalURL,
  image,
  imageAlt = 'Skin Schema premium beauty content examples',
  themeColor = '#ffffff',
  statusBarStyle = 'default',
} = Astro.props;

const metaDescription =
  description ||
  'Committed to uncovering the best in authentic, minimalistic beauty. Tips, routines, and product reviews for a serene self-care experience.';
const ogImage = image || '/media/og-image.png';
const ogImageUrl = new URL(ogImage, Astro.site || Astro.url).toString();

// If canonicalURL is not provided, use the current URL
const canonical = (canonicalURL || Astro.url).toString();
---

<head>
  <meta charset="UTF-8" />
  <meta name="description" content={metaDescription} />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1, viewport-fit=cover"
  />
  <meta name="theme-color" content={themeColor} />
  <meta name="apple-mobile-web-app-status-bar-style" content={statusBarStyle} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Canonical -->
  <link rel="canonical" href={canonical} />
  <meta name="generator" content={Astro.generator} />

  <!-- Twitter Meta Tags -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta property="twitter:domain" content="skinschema.com" />
  <meta property="twitter:url" content={canonical} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={metaDescription} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Open Graph -->
  <meta property="og:site_name" content="Skin Schema" />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="2560" />
  <meta property="og:image:height" content="1440" />
  <meta property="og:image:alt" content={imageAlt} />
  <meta name="title" content={title} />

  <!-- Google tag (gtag.js) -->
  <script
    type="text/partytown"
    is:inline
    async
    src="https://www.googletagmanager.com/gtag/js?id=G-R4BV0D0EME"></script>
  <script type="text/partytown" is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag('js', new Date());

    gtag('config', 'G-R4BV0D0EME');
  </script>
</head>
