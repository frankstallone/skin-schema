<script is:inline define:vars={{ variants }}>
  const variantPairs = variants;
  const variantKeys = variantPairs.map(([key]) => key);
  const labelMap = new Map(variantPairs);
  const root = document.querySelector('.homepage-prototype');
  const panels = Array.from(
    document.querySelectorAll('[data-prototype-variant]'),
  );
  const label = document.querySelector('[data-prototype-label]');
  const previousButton = document.querySelector('[data-prototype-prev]');
  const nextButton = document.querySelector('[data-prototype-next]');

  const getRequestedVariant = () => {
    const params = new URLSearchParams(window.location.search);
    const requested = (params.get('variant') || 'A').toUpperCase();
    return variantKeys.includes(requested) ? requested : 'A';
  };

  const setVariant = (nextVariant, updateUrl = true) => {
    panels.forEach((panel) => {
      panel.hidden = panel.dataset.prototypeVariant !== nextVariant;
    });

    root.dataset.currentVariant = nextVariant;
    label.textContent = `${nextVariant} - ${labelMap.get(nextVariant)}`;

    if (updateUrl) {
      const url = new URL(window.location.href);
      url.searchParams.set('variant', nextVariant);
      window.history.replaceState({}, '', url);
    }
  };

  const cycleVariant = (direction) => {
    const current = root.dataset.currentVariant || getRequestedVariant();
    const currentIndex = variantKeys.indexOf(current);
    const nextIndex =
      (currentIndex + direction + variantKeys.length) % variantKeys.length;
    setVariant(variantKeys[nextIndex]);
  };

  previousButton.addEventListener('click', () => cycleVariant(-1));
  nextButton.addEventListener('click', () => cycleVariant(1));

  document.addEventListener('keydown', (event) => {
    const target = event.target;
    const isEditing =
      target instanceof HTMLElement &&
      (target.matches('input, textarea, select') || target.isContentEditable);

    if (isEditing) {
      return;
    }

    if (event.key === 'ArrowLeft') {
      cycleVariant(-1);
    }

    if (event.key === 'ArrowRight') {
      cycleVariant(1);
    }
  });

  setVariant(getRequestedVariant(), false);
</script>

