---
const { class: className } = Astro.props;
---

<section
  class=`wrapper region flow prose ${className ? className : ''}`
  id="TheProblem"
>
  <div class="box w-fit mx-auto text-center">
    <h2>Need brand-ready beauty content with the trust of a real creator recommendation?</h2>
  </div>
  <div>
    <h3>
      Generic ads and rushed UGC get spotted fast.
    </h3>
    <p class="text-step-2 leading-snug">
      Skin Schema creates elevated skincare, makeup, and wellness content with
      the polish of a campaign asset and the trust of a real creator
      recommendation.
    </p>
  </div>
</section>
