{
  "name": "skin-schema",
  "type": "module",
  "version": "1.0.0",
  "author": "Frank Stallone <frank@stallone.dev>",
  "description": "Website for Skin Schema",
  "scripts": {
    "tokens:build": "node ./scripts/build-tailwind-theme.mjs",
    "tokens:test": "node --test src/css-utils/__tests__/tailwind-token-generator.test.js",
    "dev": "npm run tokens:build && astro dev",
    "start": "npm run tokens:build && astro dev",
    "build": "npm run tokens:build && astro check && astro build",
    "preview": "npm run tokens:build && astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/react": "^4.3.1",
    "@astrojs/sitemap": "^3.5.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@zachleat/details-utils": "^2.0.2",
    "@zachleat/table-saw": "^1.0.6",
    "astro": "^5.13.7",
    "classnames": "^2.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-select": "^5.8.0",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0"
  },
  "engines": {
    "node": ">=20.12.2"
  }
}
